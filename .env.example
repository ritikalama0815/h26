# Reports: in development, sample/dummy reports are returned by default so teachers can preview the UI.
# Set to false to call Gemini and use real commits/docs data locally.
# In production, dummy reports are off unless you set USE_DUMMY_REPORT=true.
USE_DUMMY_REPORT=
